{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,

  "rewrites": [
    { "source": "/demos/trainer", "destination": "/demos/trainer" },
    { "source": "/demos/barber", "destination": "/demos/barber" },

    { "source": "/intake", "destination": "/intake/intake-personal-business" },
    { "source": "/intake/personal-business", "destination": "/intake/intake-personal-business" },

    { "source": "/trainer", "destination": "/demos/trainer" },
    { "source": "/barber", "destination": "/demos/barber" }
  ],

  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/intake(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
